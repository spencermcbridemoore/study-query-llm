# =============================================================================
# Jetstream2 Deployment — Runtime Configuration
# Copy to .env.jetstream and fill in actual values.
# NEVER commit .env.jetstream — it contains secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Image reference (pinned tag or digest — never use "latest")
# ---------------------------------------------------------------------------
# Build locally or in CI, push to a registry, then set the full ref here.
#   Tag form:   ghcr.io/yourorg/study-query-llm:git-a1b2c3d
#   Digest form: ghcr.io/yourorg/study-query-llm@sha256:abc123...
IMAGE_REF=study-query-llm:local

# ---------------------------------------------------------------------------
# Public hostname (used by Caddy for TLS cert and by Panel for WS origins)
# ---------------------------------------------------------------------------
# Jetstream auto-assigns: instancename.projectcode.projects.jetstream-cloud.org
APP_DOMAIN=your-instance.xxx000000.projects.jetstream-cloud.org

# ---------------------------------------------------------------------------
# Panel server settings (internal — Caddy proxies to this)
# ---------------------------------------------------------------------------
PANEL_ADDRESS=0.0.0.0
PANEL_PORT=5006
# Comma-separated origins allowed to open WebSocket connections.
# Must include the public hostname Caddy serves on.
PANEL_ALLOW_WS_ORIGINS=${APP_DOMAIN}

# ---------------------------------------------------------------------------
# Database (Jetstream-local Postgres — isolated from experiment DB)
# ---------------------------------------------------------------------------
POSTGRES_USER=sqllm
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=study_query_jetstream
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ---------------------------------------------------------------------------
# Caddy basic-auth credentials
# ---------------------------------------------------------------------------
# Generate a bcrypt hash:  caddy hash-password --plaintext 'YourPassword'
# Then paste the hash below (including the $2a$... prefix).
CADDY_AUTH_USER=admin
CADDY_AUTH_HASH=$2a$14$REPLACE_WITH_BCRYPT_HASH

# ---------------------------------------------------------------------------
# LLM provider keys/endpoints (only those needed in production)
# ---------------------------------------------------------------------------
# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# OpenAI (optional)
# OPENAI_API_KEY=

# Local LLM (if running Ollama/vLLM on same or nearby VM)
# LOCAL_LLM_ENDPOINT=http://localhost:11434/v1
# LOCAL_LLM_API_KEY=not-needed
