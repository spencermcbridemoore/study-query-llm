# Environment Configuration Template
# Copy this to .env and fill in your actual values
# NEVER commit .env to git - it contains secrets!

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Artifact Storage Backend
# "local" (default) or "azure_blob". In strict mode and hosted env lanes, local is disallowed.
ARTIFACT_STORAGE_BACKEND=local
ARTIFACT_RUNTIME_ENV=dev            # dev | stage | prod
ARTIFACT_STORAGE_STRICT_MODE=false  # auto-enabled for stage/prod
ARTIFACT_ALLOW_CROSS_ENV_CONTAINER=false

# Azure Blob Storage (when ARTIFACT_STORAGE_BACKEND=azure_blob)
# Auth mode:
# - connection_string: local dev / ad-hoc jobs
# - managed_identity: hosted runtime with RBAC (recommended for stage/prod)
ARTIFACT_AUTH_MODE=connection_string

# Connection string mode (dev)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=...;EndpointSuffix=core.windows.net

# Managed identity mode (stage/prod)
AZURE_STORAGE_ACCOUNT_URL=https://your-account.blob.core.windows.net
AZURE_STORAGE_MANAGED_IDENTITY_CLIENT_ID=

# Container name: set once; dev/stage/prod use {AZURE_STORAGE_CONTAINER}-{lane}
AZURE_STORAGE_CONTAINER=artifacts

# Optional overrides per lane (default: artifacts-dev, artifacts-stage, artifacts-prod)
# AZURE_STORAGE_CONTAINER_DEV=artifacts-dev
# AZURE_STORAGE_CONTAINER_STAGE=artifacts-stage
# AZURE_STORAGE_CONTAINER_PROD=artifacts-prod

# Optional blob prefix and reliability knobs
AZURE_STORAGE_PREFIX=study-query-llm
AZURE_STORAGE_MAX_RETRIES=3
AZURE_STORAGE_RETRY_BACKOFF_SECONDS=0.5
AZURE_STORAGE_VERIFY_UPLOADS=true

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Hyperbolic Configuration
HYPERBOLIC_API_KEY=your-hyperbolic-api-key-here
HYPERBOLIC_ENDPOINT=https://api.hyperbolic.xyz

# Database Configuration
DATABASE_URL=sqlite:///study_query_llm.db
# For production PostgreSQL (online/Neon):
# DATABASE_URL=postgresql://user:password@your-neon-host/neondb?sslmode=require

# Local backup PostgreSQL (Docker, started with: docker compose --profile postgres up -d db)
# Used by scripts/init_local_db.py, scripts/sync_from_online.py, scripts/archive_defective_data.py
LOCAL_DATABASE_URL=postgresql://study:study@localhost:5433/study_query_local

# Langfuse Configuration (Optional)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Panel Configuration (Optional)
PANEL_APP_THEME=dark
PANEL_APP_DESIGN=material

# Azure Infrastructure - ACI TEI Manager (for HuggingFace embedding models on Azure)
# Required to create/delete Azure Container Instances running HuggingFace TEI
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id-here
AZURE_RESOURCE_GROUP=URAIT-USE1-NET-PROBLEMBANKGENERATOR-001-RGP

# ACI TEI Defaults (optional - override if needed)
ACI_TEI_LOCATION=eastus          # Azure region (must match resource group)
ACI_TEI_IDLE_TIMEOUT=1800        # Seconds before auto-deleting idle container (default 30 min)

# HuggingFace Configuration (for TEI / Inference Endpoints)
HF_API_TOKEN=your-hf-token-here  # optional; "not-needed" for public models on ACI

# Local Docker TEI Configuration
# HF_CACHE_DIR: host path mounted into the TEI container for model weights.
# Models are downloaded here once and reused across container restarts.
# The model_id itself is passed per-instance in code, not as an env var.
HF_CACHE_DIR=C:\Users\spenc\.cache\huggingface

# Local LLM Chat Provider (Ollama, vLLM, or any OpenAI-compatible chat server)
# Endpoint and auth only -- model is specified per-call in sweep script lists.
# Default points to Ollama running locally.
LOCAL_LLM_ENDPOINT=http://localhost:11434/v1
LOCAL_LLM_API_KEY=not-needed
