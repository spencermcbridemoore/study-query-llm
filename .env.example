# Environment Configuration Template
# Copy this to .env and fill in your actual values
# NEVER commit .env to git - it contains secrets!

# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your-azure-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Artifact Storage Backend
# "local" (default) or "azure_blob". In strict mode and hosted env lanes, local is disallowed.
ARTIFACT_STORAGE_BACKEND=local
ARTIFACT_RUNTIME_ENV=dev            # dev | stage | prod
ARTIFACT_STORAGE_STRICT_MODE=false  # auto-enabled for stage/prod
ARTIFACT_ALLOW_CROSS_ENV_CONTAINER=false

# Azure Blob Storage (when ARTIFACT_STORAGE_BACKEND=azure_blob)
# Auth mode:
# - connection_string: local dev / ad-hoc jobs
# - managed_identity: hosted runtime with RBAC (recommended for stage/prod)
ARTIFACT_AUTH_MODE=connection_string

# Connection string mode (dev)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=...;EndpointSuffix=core.windows.net

# Managed identity mode (stage/prod)
AZURE_STORAGE_ACCOUNT_URL=https://your-account.blob.core.windows.net
AZURE_STORAGE_MANAGED_IDENTITY_CLIENT_ID=

# Container name: set once; dev/stage/prod use {AZURE_STORAGE_CONTAINER}-{lane}
AZURE_STORAGE_CONTAINER=artifacts

# Optional overrides per lane (default: artifacts-dev, artifacts-stage, artifacts-prod)
# AZURE_STORAGE_CONTAINER_DEV=artifacts-dev
# AZURE_STORAGE_CONTAINER_STAGE=artifacts-stage
# AZURE_STORAGE_CONTAINER_PROD=artifacts-prod

# Optional blob prefix and reliability knobs
AZURE_STORAGE_PREFIX=study-query-llm
AZURE_STORAGE_MAX_RETRIES=3
AZURE_STORAGE_RETRY_BACKOFF_SECONDS=0.5
AZURE_STORAGE_VERIFY_UPLOADS=true

# Local artifact mirror backup (Azure Blob -> local filesystem)
LOCAL_ARTIFACT_BACKUP_DIR=C:\Users\spenc\study-query-llm-artifact-backup
ARTIFACT_MIRROR_MAX_CONCURRENCY=4

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# Hyperbolic Configuration
HYPERBOLIC_API_KEY=your-hyperbolic-api-key-here
HYPERBOLIC_ENDPOINT=https://api.hyperbolic.xyz

# OpenRouter Configuration (OpenAI-compatible chat API)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1
# Optional attribution headers (recommended by OpenRouter docs)
OPENROUTER_HTTP_REFERER=https://your-app-url.example
OPENROUTER_APP_TITLE=Study Query LLM

# Database Configuration
# DATABASE_URL=sqlite:///study_query_llm.db
# For production PostgreSQL (online/Neon):
# DATABASE_URL=postgresql://user:password@your-neon-host/neondb?sslmode=require
NEONDB_POSTGRES_USER=neondb_owner
NEONDB_POSTGRES_PASSWORD=strong-random-password
NEONDB_POSTGRES_DB=neondb
NEONDB_DATABASE_URL=url-made-using-NEONDB_POSTGRES_USER-and-NEONDB_POSTGRES_PASSWORD-and-NEONDB_POSTGRES_DB
JETSTREAM_POSTGRES_USER=admin
JETSTREAM_POSTGRES_PASSWORD=strong-random-password
JETSTREAM_POSTGRES_DB=db-name
JETSTREAM_DATABASE_URL=url-made-using-JETSTREAM_POSTGRES_USER-and-JETSTREAM_POSTGRES_PASSWORD-and-JETSTREAM_POSTGRES_DB
# PC -> Jetstream Postgres (deploy/jetstream docker-compose publishes db on VM 127.0.0.1:5432):
#   Full guide: deploy/jetstream/LOCAL_DEV_TUNNEL.md
#   python scripts/start_jetstream_postgres_tunnel.py
#   (needs JETSTREAM_SSH_HOST below; leave that process running)
#   DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5433/DBNAME?sslmode=prefer
#   (must use ? before sslmode= — not :sslmode= — or Postgres treats the whole string as the database name)
# Do not use hostname "db" on your PC — only works inside Jetstream Docker.
# Hostname (e.g. *.projects.jetstream-cloud.org) or public IPv4 — both work for SSH.
JETSTREAM_SSH_HOST=203.0.113.50
JETSTREAM_SSH_USER=exouser
JETSTREAM_SSH_LOCAL_PORT=5433
# JETSTREAM_SSH_PORT=22
# JETSTREAM_SSH_DEBUG=1
# Optional: non-interactive SSH password (install: pip install -e ".[jetstream-tunnel]" — pins paramiko<4 for sshtunnel)
# JETSTREAM_SSH_PASSWORD=your-ssh-password
# If unset, JETSTREAM_POSTGRES_PASSWORD is used for SSH (set JETSTREAM_SSH_PASSWORD if Linux login differs).
# Prefer public-key SSH (no sshtunnel): path to an OpenSSH private key for `ssh -i` (not the .pub file).
# PuTTY .ppk files are NOT usable here — in PuTTYgen: Conversions > Export OpenSSH key, save e.g. jetstream2_private_key_2 (no extension).
# JETSTREAM_SSH_KEY=location-of-the-private-key
# Optional: private key passphrase (uses sshtunnel; plain ssh cannot read passphrase from env)
# JETSTREAM_SSH_KEY_PASSPHRASE=your-key-passphrase
# If key is set without passphrase here, `ssh -i` runs (prompts if key is encrypted). Leave JETSTREAM_SSH_PASSWORD unset for key auth.
DATABASE_URL=url-for-the-database-to-use

# Local backup PostgreSQL (Docker, started with: docker compose --profile postgres up -d db)
# Used by scripts/init_local_db.py, scripts/sync_from_online.py, scripts/archive_defective_data.py
# Full runbook: backup local then clone Jetstream into this DB — docs/LOCAL_DB_CLONE_FROM_JETSTREAM.md
LOCAL_DATABASE_URL=postgresql://study:study@localhost:5433/study_query_local

# Docker container name for scripts/backup_local_docker_postgres.py (docker exec target; default in script is "db").
# Compose names containers <project>-db-1 — confirm with: docker ps
LOCAL_POSTGRES_SERVICE=study-query-llm-db-1

# Langfuse Configuration (Optional)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Panel Configuration (Optional)
PANEL_APP_THEME=dark
PANEL_APP_DESIGN=material

# Azure Infrastructure - ACI TEI Manager (for HuggingFace embedding models on Azure)
# Required to create/delete Azure Container Instances running HuggingFace TEI
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id-here
AZURE_RESOURCE_GROUP=URAIT-USE1-NET-PROBLEMBANKGENERATOR-001-RGP

# ACI TEI Defaults (optional - override if needed)
ACI_TEI_LOCATION=eastus          # Azure region (must match resource group)
ACI_TEI_IDLE_TIMEOUT=1800        # Seconds before auto-deleting idle container (default 30 min)

# HuggingFace Configuration (for TEI / Inference Endpoints)
HF_API_TOKEN=your-hf-token-here  # optional; "not-needed" for public models on ACI

# Local Docker TEI Configuration
# HF_CACHE_DIR: host path mounted into the TEI container for model weights.
# Models are downloaded here once and reused across container restarts.
# The model_id itself is passed per-instance in code, not as an env var.
HF_CACHE_DIR=C:\Users\spenc\.cache\huggingface

# Local LLM Chat Provider (Ollama, vLLM, or any OpenAI-compatible chat server)
# Endpoint and auth only -- model is specified per-call in sweep script lists.
# Default points to Ollama running locally.
LOCAL_LLM_ENDPOINT=http://localhost:11434/v1
LOCAL_LLM_API_KEY=not-needed
